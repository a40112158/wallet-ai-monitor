# ===== Poe AI =====
POE_API_KEY=
POE_BASE_URL=https://api.poe.com/v1
# 日常信号分析建议用便宜稳定模型；代码优化建议用强模型
POE_MODEL_SIGNAL=gpt-5.4-mini
POE_MODEL_CODE=Claude-Sonnet-4.6
AI_ENABLED=true
AI_MAX_OUTPUT_TOKENS=900
AI_TEMPERATURE=0.15
AI_TIMEOUT_SECONDS=60
# 触发式 AI：不达标的小信号不烧 points；相同输入 90 分钟内复用缓存
AI_CACHE_TTL_MINUTES=90
AI_MIN_TOTAL_DELTA_NOTIONAL=100000
AI_MIN_WALLET_COUNT_FOR_CALL=2
AI_MIN_WEIGHTED_SCORE_FOR_CALL=0

# ===== Hyperliquid =====
HL_INFO_URL=https://api.hyperliquid.xyz/info
HL_CONCURRENCY=3
HL_TIMEOUT_SECONDS=30
HL_RETRIES=6
HL_BATCH_SIZE=80
HL_BATCH_DELAY_SECONDS=2.0
# 默认全量扫描全部钱包；如果超时再改回分片。
MAX_WALLETS_PER_RUN=999999
SCAN_OFFSET=0
AUTO_SHARD_ROTATION=false
# 新钱包/新分片首次只建立基线，不把已有仓位误报成新开仓
WARMUP_MISSING_WALLETS=true

# ===== Signal filter =====
MIN_DELTA_NOTIONAL_USD=100000
MIN_SINGLE_WHALE_DELTA_USD=250000
MIN_WALLET_COUNT=3
TOP_SIGNALS_FOR_AI=8
SIGNAL_TTL_HOURS=72
DEFAULT_LEVERAGE_FOR_PNL=1
# 保守收益扣除估算成本：fee+slippage，单位 bps
CONSERVATIVE_FEE_BPS=5
CONSERVATIVE_SLIPPAGE_BPS=8

# 钱包分组基础权重；运行一段时间后还会叠加动态钱包胜率分
SMART_MONEY_WEIGHT=1.0
MONEY_PRINTER_WEIGHT=1.35

# ===== Virtual paper trading =====
VIRTUAL_TRADING_ENABLED=true
VIRTUAL_ACCOUNT_CAPITAL_USD=10000
VIRTUAL_TRADE_NOTIONAL_USD=0
VIRTUAL_MAX_OPEN_TRADES=6
VIRTUAL_MIN_AI_CONFIDENCE=70
VIRTUAL_TAKE_PROFIT_PCT=8
VIRTUAL_STOP_LOSS_PCT=3
VIRTUAL_MAX_HOLD_HOURS=168

# ===== Storage / report =====
STATE_DIR=.state
REPORT_DIR=reports
DB_PATH=.state/wallet_monitor.sqlite3
DATA_RETENTION_DAYS=180
REPORT_RETENTION_DAYS=30

# ===== Telegram optional =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# ===== Auto optimizer =====
# 本地默认只生成补丁建议，不直接改代码。
# GitHub 单工作流版会按 AI_SELF_OPTIMIZE / AI_OPTIMIZER_EVERY_N_RUNS 周期性运行；
# AI_DIRECT_PUSH=true 时，测试通过后直接推送当前分支。
ALLOW_AUTO_PATCH=0
AI_OPTIMIZER_AGGRESSIVE=1
AI_OPTIMIZER_MAX_TOKENS=5000

# ===== Single workflow AI control =====
# true = 同一个 wallet-monitor.yml 会周期性调用 AI 自动优化器
AI_SELF_OPTIMIZE=true
# 每 N 次监控运行一次 AI 自优化；30分钟一次时，4=约2小时一次，48=约每天一次
AI_OPTIMIZER_EVERY_N_RUNS=4
# true = AI patch 测试通过后直接推送当前分支；false = 只在 Actions 日志/报告中保留，不推送
AI_DIRECT_PUSH=true

# ===== Adaptive Poe budget controller =====
# 让脚本按每日目标 points 自动调低/调高 AI 触发阈值，尽量把月度预算用在强信号上。
AI_BUDGET_ADAPTIVE=true
AI_DAILY_TARGET_POINTS=33333
# 估算用；如果 Poe 价格变化，你只需要改这些变量。
AI_POINTS_PER_USD=33333
AI_SIGNAL_INPUT_COST_PER_MILLION_USD=0.68
AI_SIGNAL_OUTPUT_COST_PER_MILLION_USD=4.09
AI_CODE_INPUT_COST_PER_MILLION_USD=2.58
AI_CODE_OUTPUT_COST_PER_MILLION_USD=12.88
AI_BUDGET_MIN_THRESHOLD_MULTIPLIER=0.45
AI_BUDGET_MAX_THRESHOLD_MULTIPLIER=2.5
AI_BUDGET_MIN_TOP_N=3
AI_BUDGET_MAX_TOP_N=14

# ===== Signal lifecycle / cooldown =====
# 同币同方向短时间连续加仓默认合并，不重复刷屏；除非新增金额达到上次的倍数。
SIGNAL_COOLDOWN_MINUTES=360
SIGNAL_REALERT_MULTIPLIER=2.0
SIGNAL_EXIT_DECAY_RATIO=0.5

# ===== Market confirmation layer =====
# 给信号补充 5m/15m/1h K线、成交量、影线风险标签。
MARKET_CANDLES_ENABLED=true
MARKET_CANDLE_INTERVALS=5m,15m,1h
MARKET_CANDLE_LOOKBACK_MINUTES=180
MARKET_CANDLE_CONCURRENCY=4
MARKET_MAX_CANDLE_COINS=12

# ===== State hardening =====
# 每次运行前自动备份 SQLite，配合 GitHub cache/artifact 降低状态损坏风险。
STATE_BACKUP_ENABLED=true
STATE_BACKUP_KEEP=8


# Swing Contract Mode（中长期合约开单候选）
SWING_MODE_ENABLED=true
SWING_WINDOWS_HOURS=2,6,24,72,168
SWING_MIN_SCORE_FOR_AI=60
SWING_WATCH_SCORE=65
SWING_STRONG_SCORE=80
SWING_HORIZON_DAYS=3-14


# ===== AI parameter optimizer / 第三层参数优化 =====
# 参数优化层会根据虚拟交易、信号数量、AI成本和运行耗时，自动维护 config/ai_param_overrides.env。
AI_PARAM_OVERRIDES_ENABLED=true
AI_PARAM_OPTIMIZER_ENABLED=true
AI_PARAM_OPTIMIZER_EVERY_N_RUNS=2
AI_PARAM_DIRECT_PUSH=true
AI_PARAM_OPTIMIZER_MAX_TOKENS=2500
POE_MODEL_PARAM=Claude-Sonnet-4.6


# Wallet performance / win-rate quality layer
WALLET_PERFORMANCE_ENABLED=true
WALLET_PERF_HORIZONS_HOURS=24,72,168
WALLET_PERF_MIN_SAMPLE_SIZE=5
WALLET_PERF_WEIGHT_IN_SIGNAL=0.25
WALLET_PERF_DECAY_DAYS=30
WALLET_PERF_MIN_DELTA_NOTIONAL=50000

# AI virtual trade management / position sizing
AI_TRADE_MANAGEMENT_ENABLED=true
AI_POSITION_SIZING_ENABLED=true
AI_MIN_LEVERAGE=1
AI_MAX_LEVERAGE=10
AI_MIN_MARGIN_PCT_PER_TRADE=0.5
AI_MAX_MARGIN_PCT_PER_TRADE=8
AI_MAX_TOTAL_MARGIN_PCT=35
AI_CLOSE_MIN_CONFIDENCE=65
AI_TRADE_DECISION_MAX_TOKENS=1800

# AI signal scoring
AI_SCORING_ENABLED=true
AI_MIN_FINAL_SCORE_FOR_OPEN=65
AI_SCORE_WEIGHT=0.60
AI_RULE_SCORE_WEIGHT=0.25
AI_CONFIDENCE_SCORE_WEIGHT=0.15

# Virtual close warning alerts
VIRTUAL_CLOSE_WARNING_ENABLED=true
VIRTUAL_AI_PRE_CLOSE_MIN_CONFIDENCE=50
VIRTUAL_CLOSE_WARNING_TP_RATIO=0.75
VIRTUAL_CLOSE_WARNING_SL_RATIO=0.75
VIRTUAL_CLOSE_WARNING_MAX_HOLD_RATIO=0.80
